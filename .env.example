# CRAFT environment variable template
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# Never commit your actual .env file.
# ─────────────────────────────────────────────────────────────────────────────

# Required for Stage 3 on NQ-Tables (OpenAI text-embedding-3)
OPENAI_API_KEY=your-openai-api-key-here

# Required for Stage 3 on OTT-QA (Gemini embedding-001) and for
# preprocessing (table title/description generation, query expansion)
GEMINI_API_KEY=your-gemini-api-key-here

# Required for Stage 2 on OTT-QA (JINA Embeddings v3 REST API)
JINA_API_KEY=your-jina-api-key-here
